# Meta / Threads API
# Official Threads Profile Discovery API access token.
# Generate via Meta App Dashboard → Threads API → Generate Token.
# Required for official profile_lookup endpoint.
THREADS_ACCESS_TOKEN=""

# Cloudinary (image rehosting)
# Used to permanently store rehosted profile images.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Upstash Redis (profile caching)
# Serverless Redis for caching profile results (24h TTL).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
